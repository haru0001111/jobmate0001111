{
  "manifest_version": 3,
  "name": "JobMate ES Helper",
  "version": "0.1.0",
  "description": "採用サイトのES入力欄に対して、保存済み回答候補を表示する拡張機能",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobMate ES Helper"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
